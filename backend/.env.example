# Copy this to .env and fill in your production values
# Set these as environment variables in your hosting dashboard (Render, Railway, etc.)
# NEVER commit your real .env file to Git

MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# Set to 'production' in Render/Railway/etc.
NODE_ENV=production

JWT_SECRET=<min-32-char-random-string>
JWT_REFRESH_SECRET=<min-32-char-random-string>
PASSWORD_PEPPER=<random-secret-string>

GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>

RESEND_API_KEY=<your-resend-api-key>
FROM_EMAIL=noreply@yourdomain.com

# In production: set to your Vercel URL
# Multiple origins: comma-separate them  e.g. https://outfy.vercel.app,https://outfy.com
FRONTEND_URL=http://localhost:5173

PORT=5000

RAZORPAY_KEY_ID=<your-razorpay-key-id>
RAZORPAY_KEY_SECRET=<your-razorpay-key-secret>
